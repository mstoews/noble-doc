---
import { Icon } from "astro-icon/components";
import HeroImage from "./hero-image.astro";
import type { FooterLink } from "../types";

const links: Array<FooterLink> = [
  {
    url: "/",
    description: "Noble Ledger home",
    icon: "mdi:home",
  },
  {
    url: "/getting_started/landing_page",
    description: "Documentation",
    icon: "mdi:book-open-variant",
  },
  {
    url: "/policy/private",
    description: "Privacy Policy",
    icon: "mdi:shield-lock-outline",
  },
  {
    url: "/policy/security",
    description: "Security Policy",
    icon: "mdi:security",
  },
];

const year = new Date().getFullYear();
---

<footer class="relative flex min-h-16 items-center justify-center py-4">
  <div class="absolute inset-0 overflow-hidden opacity-40">
    <HeroImage />
  </div>
  <div class="relative flex flex-col items-center gap-2 text-sm">
    <nav aria-label="Footer">
      <ul class="flex flex-wrap items-center justify-center gap-4">
        {
          links.map((link) => (
            <li>
              <a
                href={link.url}
                aria-label={link.description}
                class="inline-flex items-center gap-1 hover:underline"
              >
                <Icon name={link.icon} class="h-4 w-4" aria-hidden="true" />
                <span>{link.description}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <p class="text-xs opacity-80">© {year} Noble Ledger. All rights reserved.</p>
  </div>
</footer>

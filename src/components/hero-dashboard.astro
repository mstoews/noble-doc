---
import { Icon } from "astro-icon/components";

const orgName = "River Oaks Condo Corp";
const fiscalYear = "FY 2026";

const stats = [
  {
    label: "Operating Fund",
    value: "$42,310",
    deltaLabel: "+$2,180 this month",
    trend: "up" as const,
  },
  {
    label: "Reserve Fund",
    value: "$218,904",
    deltaLabel: "+$1,875 this month",
    trend: "up" as const,
  },
];

const activity = [
  {
    icon: "mdi:bank-transfer-in",
    label: "EFT · Jan condo fees",
    amount: "+$16,800",
    sign: "positive" as const,
    when: "Posted today",
  },
  {
    icon: "mdi:bank-transfer-out",
    label: "Cheque #0447 · Snow clearing",
    amount: "-$1,240",
    sign: "negative" as const,
    when: "Approved 2d ago",
  },
];

const auditDays = 63;
const auditPct = Math.round(((90 - auditDays) / 90) * 100);
---

<figure
  class="w-full max-w-md sm:max-w-lg"
  aria-label="Sample Noble Ledger dashboard"
>
  <div
    class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white text-slate-900 shadow-2xl ring-1 ring-black/5 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:ring-white/10"
    aria-hidden="true"
  >
    <div
      class="flex items-center justify-between border-b border-slate-200 bg-slate-50 px-4 py-3 dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="flex items-center gap-2 min-w-0">
        <span
          class="inline-flex size-7 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white"
        >
          <Icon name="mdi:office-building" class="size-4" />
        </span>
        <div class="min-w-0">
          <div class="truncate text-xs font-semibold">{orgName}</div>
          <div class="text-[10px] text-slate-500 dark:text-slate-400">
            {fiscalYear}
          </div>
        </div>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="size-2 rounded-full bg-red-400"></span>
        <span class="size-2 rounded-full bg-amber-400"></span>
        <span class="size-2 rounded-full bg-emerald-400"></span>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-px bg-slate-200 dark:bg-slate-800">
      {
        stats.map(({ label, value, deltaLabel, trend }) => (
          <div class="flex flex-col gap-1 bg-white p-4 dark:bg-slate-950">
            <div class="text-[11px] font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">
              {label}
            </div>
            <div class="text-2xl font-bold tracking-tight">{value}</div>
            <div
              class={`flex items-center gap-1 text-xs ${trend === "up" ? "text-emerald-600 dark:text-emerald-400" : "text-red-600 dark:text-red-400"}`}
            >
              <Icon
                name={trend === "up" ? "mdi:trending-up" : "mdi:trending-down"}
                class="size-3.5"
              />
              <span>{deltaLabel}</span>
            </div>
          </div>
        ))
      }
    </div>

    <div class="border-t border-slate-200 px-4 py-3 dark:border-slate-800">
      <div class="mb-2 flex items-center justify-between">
        <div class="text-[11px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
          Recent Activity
        </div>
        <div class="text-[10px] text-slate-400">Today</div>
      </div>
      <ul class="flex flex-col gap-2">
        {
          activity.map(({ icon, label, amount, sign, when }) => (
            <li class="flex items-center gap-3">
              <span
                class={`inline-flex size-7 items-center justify-center rounded-full ${sign === "positive" ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300" : "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300"}`}
              >
                <Icon name={icon} class="size-4" />
              </span>
              <div class="min-w-0 flex-1">
                <div class="truncate text-xs font-medium">{label}</div>
                <div class="text-[10px] text-slate-500 dark:text-slate-400">
                  {when}
                </div>
              </div>
              <div
                class={`text-xs font-semibold tabular-nums ${sign === "positive" ? "text-emerald-600 dark:text-emerald-400" : "text-slate-700 dark:text-slate-300"}`}
              >
                {amount}
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="border-t border-slate-200 bg-slate-50 px-4 py-3 dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="mb-1.5 flex items-center justify-between text-xs">
        <div class="flex items-center gap-1.5 font-medium">
          <Icon name="mdi:calendar-clock" class="size-4 text-indigo-600 dark:text-indigo-400" />
          <span>Next audit package</span>
        </div>
        <span class="font-semibold tabular-nums">{auditDays} days</span>
      </div>
      <div
        class="h-1.5 w-full overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800"
      >
        <div
          class="h-full rounded-full bg-indigo-500"
          style={`width: ${auditPct}%`}
        >
        </div>
      </div>
    </div>
  </div>
  <figcaption
    class="mt-2 text-center text-xs text-slate-300/80 dark:text-slate-400"
  >
    Sample dashboard · data illustrative
  </figcaption>
</figure>
